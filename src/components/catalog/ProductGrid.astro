---
import type { Product } from '../../lib/supabase';
import ProductCard from './ProductCard.astro';

interface Props {
  products: Product[];
  storeSlug: string;
}

const { products, storeSlug } = Astro.props;
---

{products.length > 0 ? (
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4 md:gap-6">
    {products.map(product => (
      <ProductCard product={product} storeSlug={storeSlug} />
    ))}
  </div>
) : (
  <div class="text-center py-10 sm:py-16">
    <div class="text-3xl sm:text-4xl mb-2 sm:mb-3">&#128722;</div>
    <p class="text-sm sm:text-base text-gray-500">Belum ada produk yang ditampilkan.</p>
  </div>
)}
