---
import type { Store } from '../../lib/db';
import { imageUrl } from '../../lib/utils';
import WhatsAppButton from './WhatsAppButton.astro';

interface Props {
  store: Store;
  productCount: number;
  avgRating?: number;
  totalReviews?: number;
}

const { store, productCount, avgRating = 0, totalReviews = 0 } = Astro.props;
const hasLongDescription = store.description && store.description.length > 80;
const joinedDate = new Date(store.created_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'long' });
---

<header style="background-color:var(--cs-header-bg, #ffffff);border-bottom:1px solid var(--cs-header-border, #e5e7eb)">
  <div class="max-w-5xl mx-auto px-3 sm:px-4 py-5 sm:py-8">
    <div class="flex items-start sm:items-center gap-3 sm:gap-5">
      {store.logo_url ? (
        <img
          src={imageUrl(store.logo_url)}
          alt={`Logo ${store.name}`}
          class="w-14 h-14 sm:w-20 sm:h-20 rounded-full object-cover border-2 border-gray-100 flex-shrink-0 cursor-pointer"
          width="80"
          height="80"
          id="store-logo-trigger"
        />
      ) : (
        <div
          class="w-14 h-14 sm:w-20 sm:h-20 rounded-full flex items-center justify-center text-2xl sm:text-3xl font-bold flex-shrink-0 cursor-pointer"
          style="background-color: var(--cs-accent-light, #dcfce7); color: var(--cs-accent, #16a34a)"
          id="store-logo-trigger"
        >
          {store.name.charAt(0).toUpperCase()}
        </div>
      )}

      <div class="flex-1 min-w-0">
        <h1 class="text-lg sm:text-2xl md:text-3xl font-bold truncate" style="color:var(--cs-header-text, #111827)">{store.name}</h1>
        {store.description && (
          <div class="mt-0.5 sm:mt-1">
            <p class="text-sm sm:text-base line-clamp-2" style="color:var(--cs-header-subtext, #6b7280)">{store.description}</p>
            {hasLongDescription && (
              <button
                id="store-readmore-btn"
                class="text-xs sm:text-sm font-medium mt-0.5 hover:underline transition-colors"
                style="color:var(--cs-accent, #16a34a)"
                type="button"
              >
                Selengkapnya
              </button>
            )}
          </div>
        )}
        <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-1 sm:mt-2 text-xs sm:text-sm" style="color:var(--cs-header-subtext, #9ca3af)">
          {store.address && <span>&#128205; {store.address}</span>}
          <span>{productCount} produk</span>
          {totalReviews > 0 && (
            <span class="inline-flex items-center gap-1">
              <svg class="w-3.5 h-3.5 inline" viewBox="0 0 24 24" fill="#fbbf24" stroke="#fbbf24" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
              {avgRating.toFixed(1)} ({totalReviews} ulasan)
            </span>
          )}
        </div>
      </div>

      <div class="hidden md:block flex-shrink-0">
        <WhatsAppButton phone={store.wa_number} storeName={store.name} size="sm">
          Hubungi Kami
        </WhatsAppButton>
      </div>
    </div>
  </div>
</header>

<!-- Store Info Dialog -->
<div id="store-info-dialog" class="store-dialog-overlay" aria-hidden="true">
  <div class="store-dialog-content">
    <!-- Close button -->
    <button id="store-dialog-close" class="store-dialog-close" type="button" aria-label="Tutup">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Dialog Header with Logo -->
    <div class="store-dialog-header">
      {store.logo_url ? (
        <img
          src={imageUrl(store.logo_url)}
          alt={`Logo ${store.name}`}
          class="w-20 h-20 sm:w-28 sm:h-28 rounded-2xl object-cover border-2 border-white/20 shadow-lg mx-auto"
          width="112"
          height="112"
        />
      ) : (
        <div class="w-20 h-20 sm:w-28 sm:h-28 rounded-2xl flex items-center justify-center text-3xl sm:text-5xl font-bold mx-auto border-2 border-white/20 shadow-lg" style="background-color: var(--cs-accent-light, #dcfce7); color: var(--cs-accent, #16a34a)">
          {store.name.charAt(0).toUpperCase()}
        </div>
      )}
      <h2 class="text-xl sm:text-2xl font-bold mt-4 text-white">{store.name}</h2>
      {totalReviews > 0 && (
        <div class="flex items-center justify-center gap-1.5 mt-2">
          <div class="flex items-center gap-0.5">
            {[1, 2, 3, 4, 5].map(i => (
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill={i <= Math.round(avgRating) ? '#fbbf24' : '#ffffff33'} stroke="none">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>
          <span class="text-sm text-white/80">{avgRating.toFixed(1)} ({totalReviews} ulasan)</span>
        </div>
      )}
    </div>

    <!-- Dialog Body -->
    <div class="store-dialog-body">
      <!-- Description -->
      {store.description && (
        <div class="store-dialog-section">
          <h3 class="store-dialog-label">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Tentang
          </h3>
          <p class="text-sm sm:text-base text-gray-700 leading-relaxed whitespace-pre-line">{store.description}</p>
        </div>
      )}

      <!-- Info Grid -->
      <div class="grid grid-cols-2 gap-3 sm:gap-4">
        {store.address && (
          <div class="store-dialog-card col-span-2">
            <div class="store-dialog-card-icon" style="background-color:#fef2f2;color:#ef4444">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-400 font-medium">Lokasi</p>
              <p class="text-sm text-gray-700">{store.address}</p>
            </div>
          </div>
        )}

        <div class="store-dialog-card">
          <div class="store-dialog-card-icon" style="background-color:#eff6ff;color:#3b82f6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium">Produk</p>
            <p class="text-sm font-semibold text-gray-800">{productCount}</p>
          </div>
        </div>

        <div class="store-dialog-card">
          <div class="store-dialog-card-icon" style="background-color:#f0fdf4;color:#16a34a">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium">Bergabung</p>
            <p class="text-sm font-semibold text-gray-800">{joinedDate}</p>
          </div>
        </div>
      </div>

      <!-- WhatsApp CTA -->
      <div class="mt-4 sm:mt-6">
        <WhatsAppButton phone={store.wa_number} storeName={store.name} size="md" class="w-full justify-center">
          Hubungi via WhatsApp
        </WhatsAppButton>
      </div>
    </div>
  </div>
</div>

<style>
  .store-dialog-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }
  .store-dialog-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  @media (min-width: 640px) {
    .store-dialog-overlay {
      align-items: center;
    }
  }

  .store-dialog-content {
    position: relative;
    width: 100%;
    max-width: 28rem;
    max-height: 90vh;
    max-height: 90dvh;
    overflow-y: auto;
    background-color: #ffffff;
    border-radius: 1.25rem 1.25rem 0 0;
    box-shadow: 0 -4px 40px rgba(0, 0, 0, 0.15);
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .store-dialog-overlay.open .store-dialog-content {
    transform: translateY(0);
  }

  @media (min-width: 640px) {
    .store-dialog-content {
      border-radius: 1.25rem;
      transform: translateY(20px) scale(0.97);
      box-shadow: 0 24px 48px rgba(0, 0, 0, 0.2);
    }
    .store-dialog-overlay.open .store-dialog-content {
      transform: translateY(0) scale(1);
    }
  }

  .store-dialog-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background-color: rgba(255, 255, 255, 0.2);
    color: #ffffff;
    border: none;
    cursor: pointer;
    transition: background-color 0.15s;
  }
  .store-dialog-close:hover {
    background-color: rgba(255, 255, 255, 0.35);
  }

  .store-dialog-header {
    padding: 2rem 1.5rem 1.5rem;
    text-align: center;
    background: linear-gradient(135deg, var(--cs-accent, #16a34a), color-mix(in srgb, var(--cs-accent, #16a34a) 70%, #000));
    border-radius: 1.25rem 1.25rem 0 0;
  }
  @media (min-width: 640px) {
    .store-dialog-header {
      padding: 2.5rem 2rem 1.75rem;
    }
  }

  .store-dialog-body {
    padding: 1.25rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .store-dialog-body {
      padding: 1.5rem 1.75rem 2rem;
      gap: 1.25rem;
    }
  }

  .store-dialog-section {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .store-dialog-label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #9ca3af;
    margin: 0;
  }

  .store-dialog-card {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem;
    background-color: #f9fafb;
    border-radius: 0.75rem;
  }

  .store-dialog-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    flex-shrink: 0;
  }
</style>

<script>
  const dialog = document.getElementById('store-info-dialog')!;
  const closeBtn = document.getElementById('store-dialog-close')!;
  const readMoreBtn = document.getElementById('store-readmore-btn');
  const logoTrigger = document.getElementById('store-logo-trigger');

  function openDialog() {
    dialog.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeDialog() {
    dialog.classList.remove('open');
    document.body.style.overflow = '';
  }

  if (readMoreBtn) readMoreBtn.addEventListener('click', openDialog);
  if (logoTrigger) logoTrigger.addEventListener('click', openDialog);
  closeBtn.addEventListener('click', closeDialog);
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) closeDialog();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && dialog.classList.contains('open')) closeDialog();
  });
</script>
