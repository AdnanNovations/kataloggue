---
import type { Store } from '../../lib/db';
import { imageUrl } from '../../lib/utils';
import WhatsAppButton from './WhatsAppButton.astro';

interface Props {
  store: Store;
  productCount: number;
}

const { store, productCount } = Astro.props;
---

<header class="bg-white border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-3 sm:px-4 py-5 sm:py-8">
    <div class="flex items-start sm:items-center gap-3 sm:gap-5">
      {store.logo_url ? (
        <img
          src={imageUrl(store.logo_url)}
          alt={`Logo ${store.name}`}
          class="w-14 h-14 sm:w-20 sm:h-20 rounded-full object-cover border-2 border-gray-100 flex-shrink-0"
          width="80"
          height="80"
        />
      ) : (
        <div class="w-14 h-14 sm:w-20 sm:h-20 rounded-full bg-green-100 flex items-center justify-center text-2xl sm:text-3xl font-bold text-green-600 flex-shrink-0">
          {store.name.charAt(0).toUpperCase()}
        </div>
      )}

      <div class="flex-1 min-w-0">
        <h1 class="text-lg sm:text-2xl md:text-3xl font-bold text-gray-900 truncate">{store.name}</h1>
        {store.description && (
          <p class="text-gray-500 mt-0.5 sm:mt-1 text-sm sm:text-base line-clamp-2">{store.description}</p>
        )}
        <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-1 sm:mt-2 text-xs sm:text-sm text-gray-400">
          {store.address && <span>&#128205; {store.address}</span>}
          <span>{productCount} produk</span>
        </div>
      </div>

      <div class="hidden md:block flex-shrink-0">
        <WhatsAppButton phone={store.wa_number} storeName={store.name} size="sm">
          Hubungi Kami
        </WhatsAppButton>
      </div>
    </div>
  </div>
</header>
