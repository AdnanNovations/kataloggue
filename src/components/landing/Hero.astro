---
import Button from '../ui/Button.astro';
---

<section class="relative overflow-hidden min-h-[520px] md:min-h-[600px] flex items-center">
  <!-- Video background -->
  <video
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    class="absolute inset-0 w-full h-full object-cover"
  >
    <source src="/hero-bg.webm" type="video/webm" />
  </video>

  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 py-20 md:py-32 w-full">
    <div class="max-w-3xl mx-auto text-center">
      <div class="hero-animate inline-flex items-center gap-2 px-4 py-1.5 bg-white/15 backdrop-blur-sm text-white rounded-full text-sm font-medium mb-6 border border-white/20" data-delay="1">
        100% Gratis untuk UMKM Indonesia
      </div>

      <h1 class="hero-animate text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-6" data-delay="2">
        Buat Katalog Online
        <span class="text-green-400"> dalam 5 Menit</span>
      </h1>

      <p class="hero-animate text-lg md:text-xl text-gray-200 mb-10 max-w-2xl mx-auto" data-delay="3">
        Tampilkan produk UMKM Anda secara profesional. Pelanggan bisa langsung order via WhatsApp. Tanpa biaya, tanpa ribet.
      </p>

      <div class="hero-animate flex flex-col sm:flex-row gap-4 justify-center" data-delay="4">
        <Button href="/daftar" size="lg" variant="primary">
          Buat Katalog Gratis
        </Button>
        <Button href="#cara-kerja" size="lg" variant="outline-light">
          Lihat Cara Kerja
        </Button>
      </div>

      <p class="hero-animate mt-6 text-sm text-gray-300" data-delay="5">
        Gratis selamanya. Tanpa kartu kredit. Langsung pakai.
      </p>
    </div>
  </div>
</section>
