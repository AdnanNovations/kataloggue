---
import { formatPrice, imageUrl } from '../../lib/utils';

interface Props {
  products: {
    name: string;
    slug: string;
    price: number;
    image_url: string | null;
    category: string | null;
    store_name: string;
    store_slug: string;
    visitor_count: number;
  }[];
}

const { products } = Astro.props;
---

<section class="py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900">Produk Paling Dikunjungi</h2>
      <p class="mt-2 text-gray-600">Produk yang paling banyak dilihat minggu ini.</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {products.map(product => (
        <a href={`/${product.store_slug}/${product.slug}`} class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group">
          <div class="aspect-square bg-gray-100 overflow-hidden relative">
            {product.image_url ? (
              <img
                src={imageUrl(product.image_url)}
                alt={product.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                loading="lazy"
                width="300"
                height="300"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-300">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            )}
            <span class="absolute top-2 right-2 bg-blue-600 text-white text-xs font-medium px-2 py-0.5 rounded-full flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              {product.visitor_count}
            </span>
          </div>
          <div class="p-3">
            {product.category && (
              <span class="text-xs text-green-600 uppercase tracking-wide">{product.category.split(',')[0].trim()}</span>
            )}
            <h3 class="text-sm font-medium text-gray-900 line-clamp-1 mt-0.5">{product.name}</h3>
            <p class="text-sm font-bold text-gray-900 mt-1">{formatPrice(product.price)}</p>
            <p class="text-xs text-gray-400 mt-1 truncate">{product.store_name}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
