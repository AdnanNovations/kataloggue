---
import { imageUrl } from '../../lib/utils';

interface Props {
  stores: {
    name: string;
    slug: string;
    logo_url: string | null;
    product_count: number;
    visitor_count: number;
  }[];
}

const { stores } = Astro.props;
---

<section class="bg-white py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900">Toko Paling Ramai Dikunjungi</h2>
      <p class="mt-2 text-gray-600">Toko dengan pengunjung terbanyak minggu ini.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {stores.map(store => (
        <a href={`/${store.slug}`} class="flex items-center gap-4 bg-gray-50 rounded-xl p-4 hover:shadow-md transition-shadow group">
          {store.logo_url ? (
            <img
              src={imageUrl(store.logo_url)}
              alt={store.name}
              class="w-14 h-14 rounded-xl object-cover flex-shrink-0"
              loading="lazy"
              width="56"
              height="56"
            />
          ) : (
            <div class="w-14 h-14 rounded-xl bg-green-100 text-green-700 flex items-center justify-center font-bold text-2xl flex-shrink-0">
              {store.name.charAt(0).toUpperCase()}
            </div>
          )}
          <div class="min-w-0">
            <h3 class="font-semibold text-gray-900 truncate group-hover:text-green-600 transition-colors">{store.name}</h3>
            <div class="flex items-center gap-2 mt-1">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full bg-blue-100 text-blue-800">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                {store.visitor_count} pengunjung
              </span>
            </div>
            <p class="text-xs text-gray-500 mt-1">{store.product_count} produk</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
