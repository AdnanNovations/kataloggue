---
import { formatPrice, imageUrl } from '../../lib/utils';

interface Props {
  products: {
    name: string;
    slug: string;
    price: number;
    image_url: string | null;
    category: string | null;
    store_name: string;
    store_slug: string;
    avg_rating: number;
    review_count: number;
  }[];
}

const { products } = Astro.props;
---

<section class="bg-gray-50 py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900">Produk Populer</h2>
      <p class="mt-2 text-gray-600">Produk dengan ulasan terbanyak dari pembeli.</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {products.map((product, i) => (
        <a href={`/${product.store_slug}/${product.slug}`} class="animate-on-scroll bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group" data-delay={i + 1}>
          <div class="aspect-square bg-gray-100 overflow-hidden">
            {product.image_url ? (
              <img
                src={imageUrl(product.image_url)}
                alt={product.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                loading="lazy"
                width="300"
                height="300"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-300">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            )}
          </div>
          <div class="p-3">
            {product.category && (
              <span class="text-xs text-green-600 uppercase tracking-wide">{product.category.split(',')[0].trim()}</span>
            )}
            <h3 class="text-sm font-medium text-gray-900 line-clamp-1 mt-0.5">{product.name}</h3>
            <p class="text-sm font-bold text-gray-900 mt-1">{formatPrice(product.price)}</p>
            <div class="flex items-center gap-1 mt-1.5">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="#fbbf24" stroke="none">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
              <span class="text-xs text-gray-600">{product.avg_rating.toFixed(1)} ({product.review_count})</span>
            </div>
            <p class="text-xs text-gray-400 mt-1 truncate">{product.store_name}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
