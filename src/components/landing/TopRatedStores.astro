---
import { imageUrl } from '../../lib/utils';

interface Props {
  stores: {
    name: string;
    slug: string;
    logo_url: string | null;
    product_count: number;
    avg_rating: number;
    review_count: number;
  }[];
}

const { stores } = Astro.props;
---

<section class="bg-white py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900">Toko Terbaik Pilihan Pembeli</h2>
      <p class="mt-2 text-gray-600">Rating tertinggi dari ulasan pelanggan nyata.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {stores.map((store, i) => (
        <a href={`/${store.slug}`} class="animate-on-scroll flex items-center gap-4 bg-gray-50 rounded-xl p-4 hover:shadow-md transition-shadow group" data-delay={i + 1}>
          {store.logo_url ? (
            <img
              src={imageUrl(store.logo_url)}
              alt={store.name}
              class="w-14 h-14 rounded-xl object-cover flex-shrink-0"
              loading="lazy"
              width="56"
              height="56"
            />
          ) : (
            <div class="w-14 h-14 rounded-xl bg-green-100 text-green-700 flex items-center justify-center font-bold text-2xl flex-shrink-0">
              {store.name.charAt(0).toUpperCase()}
            </div>
          )}
          <div class="min-w-0">
            <h3 class="font-semibold text-gray-900 truncate group-hover:text-green-600 transition-colors">{store.name}</h3>
            <div class="flex items-center gap-1 mt-1">
              {[1, 2, 3, 4, 5].map(i => (
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill={i <= Math.round(store.avg_rating) ? '#fbbf24' : '#e5e7eb'} stroke="none">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
              ))}
              <span class="text-sm text-gray-600 ml-1">{store.avg_rating.toFixed(1)} ({store.review_count} ulasan)</span>
            </div>
            <p class="text-xs text-gray-500 mt-1">{store.product_count} produk</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
