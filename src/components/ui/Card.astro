---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className = '', hover = false } = Astro.props;
const hoverClass = hover ? 'hover:shadow-lg hover:-translate-y-1 transition-all' : '';
---

<div class={`bg-white rounded-xl shadow-md overflow-hidden ${hoverClass} ${className}`}>
  <slot />
</div>
