---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Footer from '../../components/Footer.astro';
import ReviewDialog from '../../components/reviews/ReviewDialog';
import ReviewForm from '../../components/reviews/ReviewForm';
import ImageGallery from '../../components/catalog/ImageGallery';
import VariantSelector from '../../components/catalog/VariantSelector';
import ExpandableDescription from '../../components/catalog/ExpandableDescription';
import { query } from '../../lib/db';
import { formatPrice, imageUrl, parseProductImages, parseProductVariants } from '../../lib/utils';
import { productJsonLd, productUrl } from '../../lib/seo';
import { resolveCatalogStyle, catalogStyleVars } from '../../lib/catalog-style';
import { sanitizeDescription, normalizeDescription, stripHtml } from '../../lib/sanitize';

const { toko, produk } = Astro.params;

// Get store
const { rows: stores } = await query('SELECT * FROM stores WHERE slug = $1', [toko]);
const store = stores[0];
if (!store) return Astro.redirect('/');

// Get product
const { rows: products } = await query(
  'SELECT * FROM products WHERE store_id = $1 AND slug = $2',
  [store.id, produk],
);
const product = products[0];
if (!product) return Astro.redirect(`/${toko}`);

const productImages = parseProductImages(product);
const productVariants = parseProductVariants(product.variants);

// Get other products from same store
const { rows: relatedProducts } = await query(
  'SELECT id, name, slug, price, image_url FROM products WHERE store_id = $1 AND id != $2 AND is_available = true LIMIT 4',
  [store.id, product.id],
);

// Get product review stats
const { rows: prodReviewStats } = await query(
  'SELECT COUNT(*)::int AS total, COALESCE(AVG(rating), 0)::numeric(2,1) AS avg_rating FROM product_reviews WHERE product_id = $1',
  [product.id],
);
const prodAvgRating = parseFloat(prodReviewStats[0].avg_rating);
const prodTotalReviews = prodReviewStats[0].total;

// Build dynamic site URL
const host = Astro.request.headers.get('x-forwarded-host') || Astro.request.headers.get('host') || 'kataloggue.my.id';
const siteUrl = `https://${host}`;
const fullProductUrl = `${siteUrl}/${store.slug}/${product.slug}`;

// Sanitize description
const safeDescription = product.description
  ? sanitizeDescription(normalizeDescription(product.description))
  : '';
const plainDescription = product.description ? stripHtml(product.description) : '';

// Cache
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=120');
---

<BaseLayout>
  <Fragment slot="head">
    <SEOHead
      title={`${product.name} - ${store.name}`}
      description={plainDescription || `${product.name} - ${formatPrice(product.price)}. Order via WhatsApp di ${store.name}.`}
      url={productUrl(store.slug, product.slug)}
      image={product.image_url || store.logo_url || undefined}
      jsonLd={productJsonLd(product, store)}
    />
  </Fragment>

  {(() => {
    const cs = resolveCatalogStyle(store.catalog_style, store.theme);
    return (
      <div style={catalogStyleVars(cs)}>
      <div style={`min-height:100vh;background-color:var(--cs-page-bg)${cs.pageBgImage ? `;background-image:url(${cs.pageBgImage});background-size:cover;background-position:center;background-attachment:fixed` : ''}`}>
      {cs.pageBgImage && cs.pageBgOverlay > 0 && (
        <div style={`position:fixed;inset:0;background:rgba(0,0,0,${cs.pageBgOverlay / 100});z-index:0;pointer-events:none`} />
      )}
      <div style="position:relative;z-index:1">
      <!-- Breadcrumb -->
      <nav style="background-color:var(--cs-header-bg);border-bottom:1px solid var(--cs-header-border)">
    <div class="max-w-5xl mx-auto px-3 sm:px-4 py-2 sm:py-3 text-xs sm:text-sm truncate" style="color:var(--cs-header-subtext)">
      <a href={`/${store.slug}`} class="transition-colors hover:opacity-80" style="color:var(--cs-header-subtext)">{store.name}</a>
      <span class="mx-1 sm:mx-2">/</span>
      <span style="color:var(--cs-header-text)">{product.name}</span>
    </div>
  </nav>

  <main class="max-w-5xl mx-auto px-3 sm:px-4 py-4 sm:py-8">
    <div class="rounded-xl sm:rounded-2xl overflow-hidden" style="background-color:var(--cs-detail-bg);border:1px solid var(--cs-detail-border)">
      <div class="grid md:grid-cols-2">
        <!-- Product Image Gallery -->
        <div class="overflow-hidden">
          <ImageGallery client:load images={productImages} alt={product.name} />
        </div>

        <!-- Product Info -->
        <div class="p-4 sm:p-6 md:p-8 flex flex-col">
          {product.category && (
            <div class="flex flex-wrap gap-1.5">
              {product.category.split(',').map(cat => cat.trim()).filter(Boolean).map(cat => (
                <span class="text-xs sm:text-sm uppercase tracking-wide px-2 py-0.5 rounded" style="color:var(--cs-category-label);background:var(--cs-detail-label-bg)">{cat}</span>
              ))}
            </div>
          )}
          <h1 class="text-xl sm:text-2xl md:text-3xl font-bold mt-1" style="color:var(--cs-product-name)">{product.name}</h1>

          <div class="mt-1.5">
            <ReviewDialog client:load type="product" targetId={product.id} avgRating={prodAvgRating} totalReviews={prodTotalReviews} />
          </div>

          <VariantSelector
            client:load
            basePrice={Number(product.price)}
            variants={productVariants}
            phone={store.wa_number}
            storeName={store.name}
            productName={product.name}
            isAvailable={product.is_available}
          />

          <!-- Share buttons -->
          <div class="mt-3 sm:mt-4 flex flex-wrap items-center gap-2 sm:gap-3 pt-3 sm:pt-4" style="border-top:1px solid var(--cs-detail-border)">
            <span class="text-xs sm:text-sm" style="color:var(--cs-detail-subtext)">Bagikan:</span>
            <button
              id="copy-link"
              data-url={fullProductUrl}
              class="px-3 py-1.5 text-xs sm:text-sm rounded-lg transition-colors hover:opacity-80"
              style="background:var(--cs-detail-label-bg);color:var(--cs-detail-text)"
            >
              Salin Link
            </button>
            <a
              href={`https://wa.me/?text=${encodeURIComponent(`Cek produk ini: ${product.name} - ${formatPrice(product.price)} ${fullProductUrl}`)}`}
              target="_blank"
              rel="noopener"
              class="px-3 py-1.5 text-xs sm:text-sm rounded-lg transition-colors hover:opacity-80"
              style="background:var(--cs-accent-light);color:var(--cs-accent-dark)"
            >
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Product Description -->
    {safeDescription && (
      <div class="mt-6 sm:mt-8 rounded-xl sm:rounded-2xl p-4 sm:p-6 md:p-8" style="background-color:var(--cs-detail-bg);border:1px solid var(--cs-detail-border)">
        <h2 class="text-base sm:text-lg font-semibold mb-3 sm:mb-4" style="color:var(--cs-product-name)">Deskripsi Produk</h2>
        <ExpandableDescription client:load safeHtml={safeDescription} />
      </div>
    )}

    <!-- Review Form -->
    <div class="mt-8 sm:mt-12">
      <ReviewForm client:load type="product" targetId={product.id} storeId={store.id} />
    </div>

    <!-- Related Products -->
    {relatedProducts && relatedProducts.length > 0 && (
      <section class="mt-10 sm:mt-16">
        <h2 class="text-lg sm:text-xl font-bold mb-4 sm:mb-6" style="color:var(--cs-product-name)">Produk Lainnya</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
          {relatedProducts.map(rp => (
            <a href={`/${store.slug}/${rp.slug}`} class="group">
              <div class="overflow-hidden hover:shadow-lg transition-shadow" style={`background:var(--cs-card-bg);border-radius:var(--cs-card-radius);box-shadow:var(--cs-card-shadow);border:1px solid var(--cs-card-border)`}>
                <div class="aspect-square overflow-hidden" style="background:var(--cs-detail-label-bg)">
                  {rp.image_url ? (
                    <img
                      src={imageUrl(rp.image_url)}
                      alt={rp.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                      loading="lazy"
                      width="200"
                      height="200"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-3xl sm:text-4xl" style="color:var(--cs-detail-subtext)">&#128247;</div>
                  )}
                </div>
                <div class="p-2 sm:p-3">
                  <h3 class="text-xs sm:text-sm font-medium line-clamp-1" style="color:var(--cs-product-name)">{rp.name}</h3>
                  <p class="text-xs sm:text-sm font-bold" style="color:var(--cs-price)">{formatPrice(rp.price)}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer showBadge={true} useCatalogStyle={true} />
  </div>
  </div>
  </div>
    );
  })()}
</BaseLayout>

<script define:vars={{ storeId: store.id, productId: product.id }}>
  fetch('/api/track', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ store_id: storeId, product_id: productId, page_type: 'product' }),
    keepalive: true,
  }).catch(() => {});
</script>

<script>
  const copyBtn = document.getElementById('copy-link');
  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.getAttribute('data-url') || '';
    await navigator.clipboard.writeText(url);
    const original = copyBtn.textContent;
    copyBtn.textContent = 'Tersalin!';
    setTimeout(() => { copyBtn.textContent = original; }, 2000);
  });
</script>
