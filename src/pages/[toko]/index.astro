---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import StoreHeader from '../../components/catalog/StoreHeader.astro';
import CategoryFilter from '../../components/catalog/CategoryFilter.astro';
import ProductGrid from '../../components/catalog/ProductGrid.astro';
import WhatsAppButton from '../../components/catalog/WhatsAppButton.astro';
import Footer from '../../components/Footer.astro';
import ReviewDialog from '../../components/reviews/ReviewDialog';
import ReviewForm from '../../components/reviews/ReviewForm';
import { query } from '../../lib/db';
import { storeJsonLd, storeUrl } from '../../lib/seo';
import { resolveCatalogStyle, catalogStyleVars } from '../../lib/catalog-style';

const { toko } = Astro.params;

// Skip paths with dots (e.g. sitemap.xml, robots.txt)
if (!toko || toko.includes('.')) {
  return new Response(null, { status: 404 });
}

const activeCategory = Astro.url.searchParams.get('kategori') || undefined;

// Get store by slug
const { rows: stores } = await query('SELECT * FROM stores WHERE slug = $1', [toko]);
const store = stores[0];

if (!store) {
  return new Response(null, { status: 404 });
}

// Get products (with optional category filter)
let productsQuery: string;
let productsParams: any[];

if (activeCategory) {
  productsQuery = 'SELECT * FROM products WHERE store_id = $1 AND category = $2 ORDER BY sort_order ASC, created_at DESC';
  productsParams = [store.id, activeCategory];
} else {
  productsQuery = 'SELECT * FROM products WHERE store_id = $1 ORDER BY sort_order ASC, created_at DESC';
  productsParams = [store.id];
}

const { rows: allProducts } = await query(productsQuery, productsParams);

// Get unique categories (from all products, not filtered)
const { rows: catRows } = await query(
  'SELECT DISTINCT category FROM products WHERE store_id = $1 AND category IS NOT NULL',
  [store.id],
);
const categories = catRows.map(r => r.category as string);

// Get store review stats
const { rows: reviewStats } = await query(
  'SELECT COUNT(*)::int AS total, COALESCE(AVG(rating), 0)::numeric(2,1) AS avg_rating FROM store_reviews WHERE store_id = $1',
  [store.id],
);
const storeAvgRating = parseFloat(reviewStats[0].avg_rating);
const storeTotalReviews = reviewStats[0].total;

// Cache for 5 minutes
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=600');
---

<BaseLayout>
  <Fragment slot="head">
    <SEOHead
      title={`${store.name} - Katalog Produk Online`}
      description={store.description || `Lihat katalog produk ${store.name}. Order mudah via WhatsApp.`}
      url={storeUrl(store.slug)}
      image={store.logo_url || undefined}
      jsonLd={storeJsonLd(store)}
    />
  </Fragment>

  {(() => {
    const cs = resolveCatalogStyle(store.catalog_style, store.theme);
    return (
      <div style={catalogStyleVars(cs)}>
        <div style={`min-height:100vh;background-color:var(--cs-page-bg)${cs.pageBgImage ? `;background-image:url(${cs.pageBgImage});background-size:cover;background-position:center;background-attachment:fixed` : ''}`}>
          {cs.pageBgImage && cs.pageBgOverlay > 0 && (
            <div style={`position:fixed;inset:0;background:rgba(0,0,0,${cs.pageBgOverlay / 100});z-index:0;pointer-events:none`} />
          )}
          <div style="position:relative;z-index:1">
            <StoreHeader store={store} productCount={allProducts.length} avgRating={storeAvgRating} totalReviews={storeTotalReviews} />

            <div class="max-w-5xl mx-auto px-3 sm:px-4 pt-3">
              <ReviewDialog client:load type="store" targetId={store.id} avgRating={storeAvgRating} totalReviews={storeTotalReviews} />
            </div>

            <main class="max-w-5xl mx-auto px-3 sm:px-4 py-4 sm:py-8 pb-24 md:pb-8">
              <CategoryFilter
                categories={categories}
                storeSlug={store.slug}
                activeCategory={activeCategory}
              />

              <ProductGrid products={allProducts} storeSlug={store.slug} />
            </main>

            <!-- Mobile WhatsApp sticky button -->
            <div class="md:hidden fixed bottom-4 left-4 right-4 z-40">
              <WhatsAppButton
                phone={store.wa_number}
                storeName={store.name}
                size="lg"
                class="w-full shadow-xl"
              >
                Hubungi via WhatsApp
              </WhatsAppButton>
            </div>

            <div class="max-w-5xl mx-auto px-3 sm:px-4 pb-24 md:pb-8">
              <ReviewForm client:load type="store" targetId={store.id} storeId={store.id} />
            </div>

            <Footer showBadge={true} useCatalogStyle={true} />
          </div>
        </div>
      </div>
    );
  })()}

  <script define:vars={{ storeId: store.id }}>
    fetch('/api/track', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ store_id: storeId, page_type: 'store' }),
      keepalive: true,
    }).catch(() => {});
  </script>
</BaseLayout>
