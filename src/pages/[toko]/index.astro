---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import StoreHeader from '../../components/catalog/StoreHeader.astro';
import CategoryFilter from '../../components/catalog/CategoryFilter.astro';
import ProductGrid from '../../components/catalog/ProductGrid.astro';
import WhatsAppButton from '../../components/catalog/WhatsAppButton.astro';
import Footer from '../../components/Footer.astro';
import { query } from '../../lib/db';
import { storeJsonLd, storeUrl } from '../../lib/seo';

const { toko } = Astro.params;

// Skip paths with dots (e.g. sitemap.xml, robots.txt)
if (!toko || toko.includes('.')) {
  return new Response(null, { status: 404 });
}

const activeCategory = Astro.url.searchParams.get('kategori') || undefined;

// Get store by slug
const { rows: stores } = await query('SELECT * FROM stores WHERE slug = $1', [toko]);
const store = stores[0];

if (!store) {
  return new Response(null, { status: 404 });
}

// Get products (with optional category filter)
let productsQuery: string;
let productsParams: any[];

if (activeCategory) {
  productsQuery = 'SELECT * FROM products WHERE store_id = $1 AND category = $2 ORDER BY sort_order ASC, created_at DESC';
  productsParams = [store.id, activeCategory];
} else {
  productsQuery = 'SELECT * FROM products WHERE store_id = $1 ORDER BY sort_order ASC, created_at DESC';
  productsParams = [store.id];
}

const { rows: allProducts } = await query(productsQuery, productsParams);

// Get unique categories (from all products, not filtered)
const { rows: catRows } = await query(
  'SELECT DISTINCT category FROM products WHERE store_id = $1 AND category IS NOT NULL',
  [store.id],
);
const categories = catRows.map(r => r.category as string);

// Cache for 5 minutes
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=600');
---

<BaseLayout>
  <Fragment slot="head">
    <SEOHead
      title={`${store.name} - Katalog Produk Online`}
      description={store.description || `Lihat katalog produk ${store.name}. Order mudah via WhatsApp.`}
      url={storeUrl(store.slug)}
      image={store.logo_url || undefined}
      jsonLd={storeJsonLd(store)}
    />
  </Fragment>

  <StoreHeader store={store} productCount={allProducts.length} />

  <main class="max-w-5xl mx-auto px-3 sm:px-4 py-4 sm:py-8 pb-24 md:pb-8">
    <CategoryFilter
      categories={categories}
      storeSlug={store.slug}
      activeCategory={activeCategory}
    />

    <ProductGrid products={allProducts} storeSlug={store.slug} />
  </main>

  <!-- Mobile WhatsApp sticky button -->
  <div class="md:hidden fixed bottom-4 left-4 right-4 z-40">
    <WhatsAppButton
      phone={store.wa_number}
      storeName={store.name}
      size="lg"
      class="w-full shadow-xl"
    >
      Hubungi via WhatsApp
    </WhatsAppButton>
  </div>

  <Footer showBadge={true} />
</BaseLayout>
