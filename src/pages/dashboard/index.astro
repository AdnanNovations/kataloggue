---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { query } from '../../lib/db';

const user = Astro.locals.user;

// Get store data
const { rows: stores } = await query('SELECT * FROM stores WHERE user_id = $1', [user.id]);
const store = stores[0] || null;

// Get product count
let productCount = 0;
if (store) {
  const { rows } = await query('SELECT COUNT(*)::int AS count FROM products WHERE store_id = $1', [store.id]);
  productCount = rows[0].count;
}

// Get review stats
let reviewCount = 0;
let reviewAvg = 0;
if (store) {
  const { rows: reviewRows } = await query(
    `SELECT COUNT(*)::int AS total, COALESCE(AVG(rating), 0)::numeric(2,1) AS avg_rating
     FROM (
       SELECT rating FROM store_reviews WHERE store_id = $1
       UNION ALL
       SELECT rating FROM product_reviews WHERE store_id = $1
     ) all_reviews`,
    [store.id],
  );
  reviewCount = reviewRows[0].total;
  reviewAvg = parseFloat(reviewRows[0].avg_rating);
}

// Get visitor count
let visitorCount = 0;
if (store) {
  const { rows: visitorRows } = await query(
    'SELECT COUNT(DISTINCT visitor_hash)::int AS total FROM page_views WHERE store_id = $1',
    [store.id],
  );
  visitorCount = visitorRows[0].total;
}

const hasStore = !!store;
const host = Astro.request.headers.get('x-forwarded-host') || Astro.request.headers.get('host') || 'kataloggue.my.id';
const siteUrl = `https://${host}`;
---

<DashboardLayout title="Dashboard">
  {!hasStore ? (
    <div class="bg-white rounded-xl shadow-md p-8 text-center max-w-lg mx-auto">
      <div class="text-5xl mb-4">&#127978;</div>
      <h2 class="text-xl font-bold text-gray-900 mb-2">Selamat Datang!</h2>
      <p class="text-gray-500 mb-6">Mulai dengan membuat toko online Anda terlebih dahulu.</p>
      <a
        href="/dashboard/pengaturan"
        class="inline-block bg-green-600 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-green-700 transition-colors"
      >
        Buat Toko Sekarang
      </a>
    </div>
  ) : (
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Store Info Card -->
      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="text-sm text-gray-500 mb-1">Toko Anda</div>
        <div class="text-xl font-bold text-gray-900">{store.name}</div>
        <a
          href={`/${store.slug}`}
          class="inline-block mt-3 text-sm text-green-600 hover:underline"
          target="_blank"
        >
          Lihat Katalog &rarr;
        </a>
      </div>

      <!-- Products Count Card -->
      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="text-sm text-gray-500 mb-1">Total Produk</div>
        <div class="text-3xl font-bold text-gray-900">{productCount || 0}</div>
        <a
          href="/dashboard/produk"
          class="inline-block mt-3 text-sm text-green-600 hover:underline"
        >
          Kelola Produk &rarr;
        </a>
      </div>

      <!-- Visitors Card -->
      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="text-sm text-gray-500 mb-1">Total Pengunjung</div>
        <div class="text-3xl font-bold text-gray-900">{visitorCount}</div>
        <p class="mt-3 text-xs text-gray-400">Pengunjung unik katalog Anda</p>
      </div>

      <!-- Reviews Card -->
      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="text-sm text-gray-500 mb-1">Total Ulasan</div>
        <div class="flex items-baseline gap-2">
          <span class="text-3xl font-bold text-gray-900">{reviewCount}</span>
          {reviewAvg > 0 && (
            <span class="text-sm text-amber-500 flex items-center gap-0.5">
              <svg class="w-4 h-4 inline" viewBox="0 0 24 24" fill="#fbbf24" stroke="#fbbf24" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
              {reviewAvg.toFixed(1)}
            </span>
          )}
        </div>
        <a
          href="/dashboard/ulasan"
          class="inline-block mt-3 text-sm text-green-600 hover:underline"
        >
          Lihat Ulasan &rarr;
        </a>
      </div>

      <!-- Quick Actions Card -->
      <div class="bg-white rounded-xl shadow-md p-6">
        <div class="text-sm text-gray-500 mb-3">Bagikan Katalog</div>
        <div class="flex flex-col gap-2">
          <button
            id="copy-link"
            data-url={`${siteUrl}/${store.slug}`}
            class="text-left px-4 py-2 bg-gray-50 rounded-lg text-sm hover:bg-gray-100 transition-colors"
          >
            &#128203; Salin Link Katalog
          </button>
          <a
            href={`https://wa.me/?text=${encodeURIComponent(`Cek katalog produk kami: ${siteUrl}/${store.slug}`)}`}
            target="_blank"
            class="px-4 py-2 bg-green-50 text-green-700 rounded-lg text-sm hover:bg-green-100 transition-colors"
          >
            &#128172; Bagikan via WhatsApp
          </a>
        </div>
      </div>
    </div>
  )}
</DashboardLayout>

<script>
  const copyBtn = document.getElementById('copy-link');
  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.getAttribute('data-url') || '';
    await navigator.clipboard.writeText(url);
    const original = copyBtn.innerHTML;
    copyBtn.textContent = 'Tersalin!';
    setTimeout(() => { copyBtn.innerHTML = original; }, 2000);
  });
</script>
