---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StoreSettingsForm from '../../components/dashboard/StoreSettingsForm';
import { query } from '../../lib/db';

const user = Astro.locals.user;

const { rows: stores } = await query('SELECT * FROM stores WHERE user_id = $1', [user.id]);
const store = stores[0] || null;
---

<DashboardLayout title="Pengaturan Toko">
  <StoreSettingsForm
    client:load
    store={store ? {
      id: store.id,
      name: store.name,
      slug: store.slug,
      description: store.description || '',
      wa_number: store.wa_number,
      address: store.address || '',
      logo_url: store.logo_url || '',
    } : undefined}
  />
</DashboardLayout>
