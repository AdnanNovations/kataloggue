---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ProductList from '../../components/dashboard/ProductList';
import { query } from '../../lib/db';

const user = Astro.locals.user;

// Get store
const { rows: stores } = await query('SELECT * FROM stores WHERE user_id = $1', [user.id]);
const store = stores[0];

if (!store) {
  return Astro.redirect('/dashboard/pengaturan');
}

// Get products with review stats and visitor count
const { rows: products } = await query(
  `SELECT p.*,
     COALESCE(AVG(pr.rating), 0)::numeric(2,1) AS avg_rating,
     COUNT(DISTINCT pr.id)::int AS review_count,
     COUNT(DISTINCT pv.visitor_hash)::int AS visitor_count
   FROM products p
   LEFT JOIN product_reviews pr ON pr.product_id = p.id
   LEFT JOIN page_views pv ON pv.product_id = p.id
   WHERE p.store_id = $1
   GROUP BY p.id
   ORDER BY p.sort_order ASC, p.created_at DESC`,
  [store.id],
);
---

<DashboardLayout title="Produk">
  <ProductList
    client:load
    initialProducts={products || []}
    storeSlug={store.slug}
  />
</DashboardLayout>
