---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import CatalogBuilder from '../../components/dashboard/CatalogBuilder';
import { query } from '../../lib/db';
import { resolveCatalogStyle } from '../../lib/catalog-style';

const user = Astro.locals.user;

const { rows: stores } = await query('SELECT * FROM stores WHERE user_id = $1', [user.id]);
const store = stores[0] || null;

if (!store) {
  return Astro.redirect('/dashboard/pengaturan');
}

const catalogStyle = resolveCatalogStyle(store.catalog_style, store.theme);
---

<DashboardLayout title="Tampilan Katalog">
  <CatalogBuilder
    client:load
    initialStyle={catalogStyle}
    storeName={store.name}
    storeSlug={store.slug}
  />
</DashboardLayout>
